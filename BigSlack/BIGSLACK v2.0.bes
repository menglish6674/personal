<?xml version="1.0" encoding="UTF-8"?>
<BES xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="BES.xsd">
	<Task>
		<Title>BIGSLACK v2.0</Title>
		<Description><![CDATA[<P><STRONG><FONT size=3>Action&nbsp;Parameters:</FONT></STRONG></P>
<P>&nbsp;<INPUT onfocus="if (this.value == 'OP Name') {this.value = '';}" onblur="if (this.value == '') {this.value = 'OP Name';}" id=RemoteOP title="Enter the Operator Name with API Rights" value="OP Name" name=RemoteOP>&nbsp;<FONT color=#0080ff><STRONG>&lt;&lt;&nbsp;</STRONG></FONT> Enter the&nbsp;IEM Server Operator Name<BR>&nbsp;<INPUT id=RemoteOPPass title="Enter the Operator Password" type=password name=RemoteOPPass>&nbsp;&nbsp; <FONT color=#0080ff><STRONG>&lt;&lt;</STRONG></FONT>&nbsp; Enter the&nbsp;IEM Server Operator Password&nbsp;<BR><script>
			document.body.ontakeaction = function() {
				var theRemoteOP = document.getElementById( "RemoteOP" ).value;
				var theRemoteOPPass = document.getElementById( "RemoteOPPass" ).value;
				TakeSecureFixletAction( Relevance('id of current fixlet'), Relevance('id of current bes site'), "Action1", {}, { RemoteOP: theRemoteOP , RemoteOPPass: theRemoteOPPass } );
				return false;
			}
			</script><BR><STRONG>_____________________________________________________________________________________________________</STRONG> </P>
<P><FONT size=4><STRONG>BIGSLACK v2.0<BR></STRONG></FONT><SPAN lang=EN><BR>Bigslack integrates the Deployment Health Check Dashboard with SLACK and will also notify you of any new site content</SPAN></P>
<P><SPAN lang=EN>This will run every 2 hours (by default).</SPAN></P>
<P><SPAN lang=EN><STRONG><FONT size=3><U>Prerequisites:</U></FONT><BR>You must create or use an existing Slack Workspace<BR>You must create or use an existing Slack Channel<BR>You must create a SLACK Webhook App<BR>The endpoint that will be the target of this action should be available 24/7.&nbsp; It will also&nbsp;need&nbsp;Curl installed.</STRONG></SPAN><SPAN lang=EN></P></SPAN>]]></Description>
		<Relevance>(name of operating system starts with "Win")</Relevance>
		<Relevance><![CDATA[version of client >= "9.0"]]></Relevance>
		<Category>Bigfix Maintenance</Category>
		<Source>michael.english@hcl-software.com</Source>
		<SourceID></SourceID>
		<SourceReleaseDate>2019-03-02</SourceReleaseDate>
		<SourceSeverity></SourceSeverity>
		<CVENames></CVENames>
		<SANSID></SANSID>
		<MIMEField>
			<Name>x-fixlet-modification-time</Name>
			<Value>Fri, 10 Jul 2026 15:49:18 +0000</Value>
		</MIMEField>
		<Domain>BES </Domain>
		<DefaultAction ID="Action1">
			<Description>
				<PreLink>Click </PreLink>
				<Link>here</Link>
				<PostLink> to deploy this action.</PostLink>
			</Description>
			<ActionScript MIMEType="application/x-Fixlet-Windows-Shell"><![CDATA[//Pathname to curl
action parameter query "cURL" with description "Please enter the full path to curl binary" with default value "%22c:\curl\bin\curl.exe%22"

//IP or Hostname and PORT of Bigfix Server:
action parameter query "BFServer" with description "Please enter the IP address or Hostname and Port of the Bigfix REST API (must be resolvable):" with default value "11.11.11.11:52311"

//Webhook URL
action parameter query "WebhookURL" with description "Please enter your Webhook URL" with default value "https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX"

//Slack #CHANNEL
action parameter query "CHANNEL" with description "Please enter the Slack Channel to post to" with default value "#bf-integration"

//Check for C:\BIGSLACK
if {not exist folder "C:\BIGSLACK"}
	dos mkdir "C:\BIGSLACK"
endif

wait cmd.exe /C del /Q "c:\bigslack\*.*"

//turn off certain checks by commenting the line out
//Create check files
//BES Relay Health | Number of Clients Per BES Relay | Risk:HIGH
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20unique%20values%20whose%20%28multiplicity%20of%20it%20%3E%201000%29%20of%20%28values%20of%20results%20of%20bes%20property%20%22relay%22%29%29%20then%20%28%22BES%20Relay%20Health%20%7C%20Number%20of%20Clients%20Per%20BES%20Relay%20%7C%20Risk%3AHIGH%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22BES%20Relay%20Health%20%7C%20Number%20of%20Clients%20Per%20BES%20Relay%20%7C%20Risk%3AHIGH%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Number of Clients Per BES Relay.txt"
//BES Relay Health | BES Relay Version | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(%28if%20%28it%20contains%20%22%27%2B%20txFailed%20%2B%27%22%29%20then%20%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Version%20%7C%20Risk%3AMedium%20%3D%20%2AFAIL%2A%22%20else%20if%20%28it%20contains%20%22%27%2B%20txWarning%20%2B%27%22%29%20then%20%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Version%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Version%20%7C%20Risk%3AMedium%20%3D%20PASS%22%29%20of%20concatenation%20of%20%28%20if%20%28%28preceding%20text%20of%20last%20%22.%22%20of%20preceding%20text%20of%20last%20%22.%22%20of%20item%200%20of%20it%29%20%3D%20%28preceding%20text%20of%20last%20%22.%22%20of%20preceding%20text%20of%20last%20%22.%22%20of%20value%20of%20item%201%20of%20it%29%29%20then%20%28%22%27%20%2B%20txPassed%20%2B%20%27%22%29%20else%20%28%22%27%2B%20txWarning%20%2B%27%22%29%20%29%20of%20%28%28preceding%20text%20of%20first%20%22%2C%22%20of%20%28%28concatenation%20%22%2C%22%20of%20%28values%20whose%20%28it%20%21%3D%20%22Not%20Installed%22%29%20of%20results%20of%20BES%20Property%20%22BES%20Server%20Version%22%29%29%20%26%20%22%2C%22%29%29%20%2C%20results%20whose%20%28value%20of%20it%20%21%3D%20%22Not%20Installed%22%29%20of%20BES%20Property%20%22BES%20Relay%20Version%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\BES Relay Version.txt"
//BES Relay Health | BES Relay Service Stopped | Risk:High
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20results%20whose%20%28value%20of%20it%20as%20lowercase%20contains%20%22yes%20-%20stopped%22%29%20of%20bes%20property%20%22BES%20Relay%20Service%20Installed%22%29%20then%20%28%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Service%20Stopped%20%7C%20Risk%3AHigh%20-%20%2AFAIL%2A%22%29%20else%20%28%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Service%20Stopped%20%7C%20Risk%3AHigh%20-%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\BES Relay Service Stopped.txt"
//BES Relay Health | Download Folders | Risk:Critical
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28applicable%20computer%20count%20of%20BES%20Fixlets%20whose%20%28name%20of%20site%20of%20it%20%3D%20%22BES%20Support%22%20and%20id%20of%20it%20%3D%20535%20%29%20%3E%200%29%20then%20%28%22BES%20Relay%20Health%20%7C%20Download%20Folders%20%7C%20Risk%3ACritical%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22BES%20Relay%20Health%20%7C%20Download%20Folders%20%7C%20Risk%3ACritical%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Download Folders.txt"
//BES Relay Health | BES Relay Free Disk Space | Risk:High
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exist%20preceding%20texts%20whose%20%28it%20as%20integer%20%3C%20500%29%20of%20firsts%20%22%20%22%20of%20values%20whose%20%28it%20as%20string%20%21%3D%20%22N%2FA%22%29%20of%20results%20whose%20%28exists%20value%20of%20it%29%20of%20bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3ABES%20Relay%20Free%20Disk%20Space%22%20and%20name%20of%20site%20of%20source%20analysis%20of%20it%20%3D%20%22%27%20%2B%20currentSite%20%2B%20%27%22%29%29%20then%20%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Free%20Disk%20Space%20%7C%20Risk%3AHigh%20%3D%20%2AFAIL%2A%22%20else%20if%20%28exist%20preceding%20texts%20whose%20%28it%20as%20integer%20%3C%201000%29%20of%20firsts%20%22%20%22%20of%20values%20whose%20%28it%20as%20string%20%21%3D%20%22N%2FA%22%29%20of%20results%20of%20bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3ABES%20Relay%20Free%20Disk%20Space%22%20and%20name%20of%20site%20of%20source%20analysis%20of%20it%20%3D%20%22%27%20%2B%20currentSite%20%2B%20%27%22%29%29%20then%20%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Free%20Disk%20Space%20%7C%20Risk%3AHigh%20%3D%20WARNING%22%20else%20%22BES%20Relay%20Health%20%7C%20BES%20Relay%20Free%20Disk%20Space%20%7C%20Risk%3AHigh%20%3D%20PASS%22)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\BES Relay Free Disk Space.txt"
//BES Relay Health | FillDB Bufferdir File Counts | Risk:Critical
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20values%20whose%20%28it%20as%20integer%20%3E%2050%29%20of%20results%20whose%20%28exists%20value%20of%20it%20AND%20value%20of%20it%20%21%3D%20%22N%2FA%22%29%20of%20%28bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3ANumber%20of%20Files%20in%20FillDB%20Bufferdir%22%20and%20name%20of%20site%20of%20source%20analysis%20of%20it%20%3D%20%22%27%20%2B%20currentSite%20%2B%20%27%22%29%29%29%20then%20%28%22BES%20Relay%20Health%20%7C%20FillDB%20Bufferdir%20File%20Counts%20%7C%20Risk%3ACritical%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22BES%20Relay%20Health%20%7C%20FillDB%20Bufferdir%20File%20Counts%20%7C%20Risk%3ACritical%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\FillDB Bufferdir File Counts.txt"
//******THIS IS BROKEN*** BES Relay Health | Gather Status | Risk:Medium
//wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20results%20whose%20%28exists%20values%20whose%20%28now%20-%20%28preceding%20text%20of%20first%20%22%2522%3E%22%20of%20following%20text%20of%20first%20%22LastRequestedTime%3D%2522%22%20of%20it%29%20as%20universal%20time%20%3C%201%2Aday%29%20of%20it%29%20of%20bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3AGather%20Status%20Failures%22%20and%20name%20of%20site%20of%20source%20analysis%20of%20it%20%3D%20%22%27%20%2B%20currentSite%20%2B%20%27%22%29%29%20then%20%22BES%20Relay%20Health%20%7C%20Gather%20Status%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22BES%20Relay%20Health%20%7C%20Gather%20Status%20%7C%20Risk%3AMedium%20%3D%20PASS%22)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Gather Status.txt"
//BES Relay Health | Actionsite Versions | Risk:High
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(%28if%20%28it%20contains%20%22%27%2B%20txFailed%20%2B%27%22%29%20then%20%22BES%20Relay%20Health%20%7C%20Actionsite%20Versions%20%7C%20Risk%3AHigh%20%3D%20%2AFAIL%2A%22%20else%20if%20%28it%20contains%20%22%27%2B%20txWarning%20%2B%27%22%29%20then%20%22BES%20Relay%20Health%20%7C%20Actionsite%20Versions%20%7C%20Risk%3AHigh%20%3D%20WARNING%22%20else%20%22BES%20Relay%20Health%20%7C%20Actionsite%20Versions%20%7C%20Risk%3AHigh%20%3D%20PASS%22%29%20of%20concatenation%20%22%22%20of%20%28if%20%28value%20of%20item%201%20of%20it%20as%20integer%20%3C%20item%200%20of%20it%20as%20integer%20-%201%29%20then%20%22%27%2B%20txFailed%20%2B%27%22%20else%20if%20%28value%20of%20item%201%20of%20it%20as%20integer%20%3C%3D%20item%200%20of%20it%20as%20integer%20-%201%29%20then%20%22%27%2B%20txWarning%20%2B%27%22%20else%20%22%27%20%2B%20txPassed%20%2B%20%27%22%29%20of%20%28maximum%20of%20%28%28values%20of%20results%20from%20%28bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3AActionsite%20Version%22%29%29%20of%20bes%20computers%20whose%20%28root%20server%20flag%20of%20it%20%3D%20TRUE%29%29%20as%20integer%29%2C%20results%20whose%20%28exists%20value%20of%20it%29%20of%20bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3AActionsite%20Version%22%29%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Actionsite Versions.txt"
//BES Relay Health | Registration List Size | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20preceding%20texts%20whose%20%28it%20as%20integer%20%3E%2050000%29%20of%20firsts%20%22%20%22%20of%20values%20of%20results%20whose%20%28value%20of%20it%20%21%3D%20%22N%2FA%22%29%20of%20bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3ARegistration%20List%20Size%22%20and%20name%20of%20site%20of%20source%20analysis%20of%20it%20%3D%20%22%27%20%2B%20currentSite%20%2B%20%27%22%29%29%20then%20%22BES%20Relay%20Health%20%7C%20Registration%20List%20Size%20%7C%20Risk%3AMedium%20%3D%20%2AFAIL%2A%22%20else%20if%20%28exists%20preceding%20texts%20whose%20%28it%20as%20integer%20%3E%2030000%29%20of%20firsts%20%22%20%22%20of%20values%20of%20results%20whose%20%28value%20of%20it%20%21%3D%20%22N%2FA%22%29%20of%20bes%20properties%20whose%20%28name%20of%20it%20%3D%20%22BES%20Health%20Checks%3A%3ARegistration%20List%20Size%22%20and%20name%20of%20site%20of%20source%20analysis%20of%20it%20%3D%20%22%27%20%2B%20currentSite%20%2B%20%27%22%29%29%20then%20%22BES%20Relay%20Health%20%7C%20Registration%20List%20Size%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22BES%20Relay%20Health%20%7C%20Registration%20List%20Size%20%7C%20Risk%3AMedium%20%3D%20PASS%22)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Registration List Size.txt"
//BES Console Health | Too Many Offline Computers | Risk:Critical
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28%28number%20of%20results%20whose%20%28exists%20value%20of%20it%20and%20%28now%20-%20value%20of%20it%20as%20local%20time%20%3E%203%20%2A%20hour%29%29%20of%20bes%20property%20%22Last%20Report%20Time%22%29%20%3E%20%28%28Number%20of%20BES%20Computers%29%20%2A%20%284%20%2F%205%20as%20floating%20point%29%29%29%20then%20%28%22BES%20Console%20Health%20%7C%20Too%20Many%20Offline%20Computers%20%7C%20Risk%3ACritical%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22BES%20Console%20Health%20%7C%20Too%20Many%20Offline%20Computers%20%7C%20Risk%3ACritical%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Too Many Offline Computers.txt"
//BES Console Health | Stopped And Expired Actions | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(%28if%20%28it%20%3E%2010000%29%20then%20%22BES%20Console%20Health%20%7C%20Stopped%20And%20Expired%20Actions%20%7C%20Risk%3AMedium%20%3D%20%2AFAIL%2A%22%20else%20if%20%28it%20%3E%205000%29%20then%20%22BES%20Console%20Health%20%7C%20Stopped%20And%20Expired%20Actions%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22BES%20Console%20Health%20%7C%20Stopped%20And%20Expired%20Actions%20%7C%20Risk%3AMedium%20%3D%20PASS%22%29%20of%20number%20of%20BES%20Actions%20whose%20%28%28Exists%20parent%20group%20whose%20%28state%20of%20it%20%3D%20%22Expired%22%20or%20state%20of%20it%20%3D%20%22Stopped%22%29%20of%20it%29%20or%20%20%28not%20exists%20parent%20group%20of%20it%20and%20%28state%20of%20it%20%3D%20%22Expired%22%20or%20state%20of%20it%20%3D%20%22Stopped%22%29%29%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Stopped And Expired Actions.txt"
//BES Console Health | Stopped And Expired Hidden Actions | Risk:Medium
