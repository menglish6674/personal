delete "C:\BIGSLACK\BIGSLACK.data"
copy __appendfile "c:\BIGSLACK\BIGSLACK.data"

//New Content
delete __appendfile
delete "C:\BIGSLACK\NEWCONTENT.data"
appendfile {concatenation "%0d%0a" of (preceding texts of firsts "</Answer>" of (following texts of firsts "<Answer type=%22string%22>" of (lines of file "c:\BIGSLACK\New Content.txt")))}
copy __appendfile "c:\BIGSLACK\NEWCONTENT.data"

//Post Health Check data to Slack
pause while {not exist file "c:\BIGSLACK\BIGSLACK.data"}
if {exists file "c:\bigslack\bigslack.data" whose (exist lines of it AND line 1 of it !="")}
	wait {parameter "cURL" of action} -X POST -d "payload={{'channel': '{parameter "CHANNEL" of action}', 'username': 'bfbot', 'text': '{"*The following components from the " & ("_" & preceding text of last ":" of parameter "BFServer" of action as uppercase & "_") & " BigFix Deployment Health Check Dashboard require attention:*\n" & (concatenation "\n" of lines whose (it contains "FAIL" OR it contains "WARNING" OR it contains "New Content") of file "c:\bigslack\bigslack.data")}'}" {parameter "WebhookURL" of action}
endif

//Post New Content data to Slack
if {exists file "c:\bigslack\newcontent.data" whose (exist lines of it AND line 1 of it !="")}
	wait {parameter "cURL" of action} -X POST -d "payload={{'channel': '{parameter "CHANNEL" of action}', 'username': 'bfbot', 'text': '{"*New Content Available For:* " & line 1 of file "c:\bigslack\newcontent.data"}'}" {parameter "WebhookURL" of action}
endif]]></ActionScript>
