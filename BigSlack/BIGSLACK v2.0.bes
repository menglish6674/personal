wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20bes%20actions%20whose%20%28length%20of%20applicability%20relevance%20of%20it%20%3E%2050000%20AND%20%28if%20%28exists%20source%20fixlet%20of%20it%29%20then%20%28%28not%20exists%20mime%20field%20%22no-relevance-health-check%22%20of%20it%20OR%20mime%20field%20%22no-relevance-health-check%22%20of%20it%20%3D%20%22false%22%29%20of%20source%20fixlet%20of%20it%29%20else%20%28if%20%28version%20string%20%22ProductVersion%22%20of%20module%20%22BESSessionInspect.dll%22%20as%20version%20%3C%20%229.1%22%29%20then%20%28true%29%20else%20%28not%20exists%20mime%20field%20%22no-relevance-health-check%22%20of%20it%20OR%20mime%20field%20%22no-relevance-health-check%22%20of%20it%20%3D%20%22false%22%29%29%29%29%29%20then%20%28%22Deployment%20Optimization%20%7C%20Action%20Applicability%20Too%20Large%20%7C%20Risk%3AMedium%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22Deployment%20Optimization%20%7C%20Action%20Applicability%20Too%20Large%20%7C%20Risk%3AMedium%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Action Applicability Too Large.txt"
//Deployment Optimization| Operators Using Policy Actions | Risk:High
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20unique%20values%20whose%20%28multiplicity%20of%20it%20%3E%2010%29%20of%20%28links%20of%20issuers%20of%20top%20level%20BES%20Actions%20whose%20%28not%20master%20flag%20of%20issuer%20of%20it%20and%20not%20exists%20end%20date%20of%20it%20and%20state%20of%20it%20%3D%20%22Open%22%29%20as%20string%29%29%20then%20%28%22Deployment%20Optimization%20%7C%20Operators%20Using%20Policy%20Actions%20%7C%20Risk%3AHigh%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22Deployment%20Optimization%20%7C%20Operators%20Using%20Policy%20Actions%20%7C%20Risk%3AHigh%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Operators Using Policy Actions.txt"
//Deployment Optimization| Support Analysis Activation | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20BES%20Fixlets%20whose%20%28analysis%20flag%20of%20it%20and%20name%20of%20site%20of%20it%20%3D%20%22%27%20%2B%20BESSupport.innerText%20%2B%20%27%22%20and%20%28%20id%20of%20it%20%3D%20204%20or%20id%20of%20it%20%3D%20205%20%29%20and%20%28not%20exists%20activations%20of%20it%20or%20not%20exists%20activations%20whose%20%28active%20flag%20of%20it%29%20of%20it%29%29%29%20then%20%22Deployment%20Optimization%20%7C%20Support%20Analysis%20Activation%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22Deployment%20Optimization%20%7C%20Support%20Analysis%20Activation%20%7C%20Risk%3AMedium%20%3D%20PASS%22)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Support Analysis Activation.txt"
//Deployment Optimization| Policy Actions Not Targeted By Property | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(%28if%20%28it%20%3E%20100%29%20then%20%22Deployment%20Optimization%20%7C%20Policy%20Actions%20Not%20Targeted%20By%20Property%20%7C%20Risk%3AMedium%20%3D%20%2AFAIL%2A%22%20else%20if%20%28it%20%3E%2010%29%20then%20%22Deployment%20Optimization%20%7C%20Policy%20Actions%20Not%20Targeted%20By%20Property%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22Deployment%20Optimization%20%7C%20Policy%20Actions%20Not%20Targeted%20By%20Property%20%7C%20Risk%3AMedium%20%3D%20PASS%22%29%20of%20number%20of%20top%20level%20BES%20Actions%20whose%20%28not%20exists%20end%20date%20of%20it%20and%20not%20targeted%20by%20property%20flag%20of%20it%20and%20state%20of%20it%20%3D%20%22Open%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Policy Actions Not Targeted By Property.txt"
//Deployment Optimization| Superseded Fixlets | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20bes%20actions%20whose%20%28state%20of%20it%20%3D%20%22Open%22%20and%20name%20of%20source%20fixlet%20of%20it%20as%20string%20as%20lowercase%20contains%20%22superseded%22%20and%20%28not%20exists%20parent%20group%20of%20it%20or%20state%20of%20parent%20group%20of%20it%20%3D%20%22Open%22%29%29%29%20then%20%22Deployment%20Optimization%20%7C%20Superseded%20Fixlets%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22Deployment%20Optimization%20%7C%20Superseded%20Fixlets%20%7C%20Risk%3AMedium%20%3D%20PASS%22)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Superseded Fixlets.txt"
//Deployment Optimization| Statistical Property Evaluation Period | Risk:High
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20BES%20Properties%20whose%20%28keep%20statistics%20flag%20of%20it%20and%20exists%20evaluation%20period%20of%20it%29%29%20then%20%28%22Deployment%20Optimization%20%7C%20Statistical%20Property%20Evaluation%20Period%20%7C%20Risk%3AHigh%20%3D%20%2AFAIL%2A%22%29%20else%20%28%22Deployment%20Optimization%20%7C%20Statistical%20Property%20Evaluation%20Period%20%7C%20Risk%3AHigh%20%3D%20PASS%22%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Statistical Property Evaluation Period.txt"
//Deployment Optimization| Efficient MIME | Risk:Medium
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28exists%20BES%20Fixlets%20whose%20%28analysis%20flag%20of%20it%20and%20name%20of%20site%20of%20it%20%3D%20%22%27%20%2B%20BESSupport.innerText%20%2B%20%27%22%20and%20id%20of%20it%20%3D%20204%20and%20exists%20activation%20of%20it%20and%20%28exists%20activation%20whose%20%28active%20flag%20of%20it%29%20of%20it%29%29%29%20then%20%28if%20%28exists%20bes%20deployment%20option%20%22usePre70ClientCompatibleMIME%22%20AND%20value%20of%20bes%20deployment%20option%20%22usePre70ClientCompatibleMIME%22%20as%20boolean%29%20then%20%28%22Deployment%20Optimization%20%7C%20Efficient%20MIME%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%29%20else%20%28if%20%28exists%20values%20whose%20%28it%20as%20version%20%3C%20%227.0%22%29%20of%20results%20of%20bes%20property%20%22BES%20Client%20Version%22%29%20then%20%22Deployment%20Optimization%20%7C%20Efficient%20MIME%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22Deployment%20Optimization%20%7C%20Efficient%20MIME%20%7C%20Risk%3AMedium%20%3D%20PASS%22%29%29%20else%20%28%28if%20%28exists%20bes%20deployment%20option%20%22usePre70ClientCompatibleMIME%22%20AND%20value%20of%20bes%20deployment%20option%20%22usePre70ClientCompatibleMIME%22%20as%20boolean%29%20then%20%22Deployment%20Optimization%20%7C%20Efficient%20MIME%20%7C%20Risk%3AMedium%20%3D%20WARNING%22%20else%20%22Deployment%20Optimization%20%7C%20Efficient%20MIME%20%7C%20Risk%3AMedium%20%3D%20PASS%22%29%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\Efficient MIME.txt"
//Deployment Optimization| License Expiration | Risk:Low
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(if%20%28%28expiration%20date%20of%20BES%20License%20-%20now%29%20%2F%20%28day%29%20%3C%200%29%20then%20%22Deployment%20Optimization%20%7C%20License%20Expiration%20%7C%20Risk%3ALow%20%3D%20%2AFAIL%2A%22%20else%20if%20%28%28expiration%20date%20of%20BES%20License%20-%20now%29%20%2F%20%28day%29%20%3C%2015%29%20then%20%22Deployment%20Optimization%20%7C%20License%20Expiration%20%7C%20Risk%3ALow%20%3D%20WARNING%22%20else%20%22Deployment%20Optimization%20%7C%20License%20Expiration%20%7C%20Risk%3ALow%20%3D%20PASS%22)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\License Expiration.txt"
//New Content Available
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(concatenation%20%22%20%7C%20%22%20of%20%28items%200%20of%20it%20as%20string%29%20of%20%20%28elements%20of%20item%200%20of%20it%2C%20elements%20of%20item%201%20of%20it%29%20whose%20%28item%201%20of%20it%20starts%20with%20item%200%20of%20it%29%20of%20%28set%20of%20%28unique%20values%20of%20%28%28if%20%28exists%20Names%20of%20Sites%20of%20it%20%7C%20false%29%20then%20%28concatenations%20%22%250A%22%20of%20%28Names%20of%20Sites%20of%20it%20as%20string%29%29%20else%20%28%22%3Cnone%3E%22%29%29%29%20of%20bes%20fixlets%20whose%20%28%28%28Source%20Release%20Date%20of%20it%20%3E%3D%28preceding%20text%20of%20last%203%20of%20%28preceding%20text%20of%20first%20%22%3A%22%20of%20%28now%20as%20string%29%29%20as%20date%29-%281%2Aday%29%29%29%29%29%2C%20set%20of%20%28%28if%20%28exists%20Name%20of%20it%20%7C%20false%29%20then%20%28concatenations%20%22%250A%22%20of%20%28Name%20of%20it%20as%20string%29%29%20else%20%28%22%3Cnone%3E%22%29%29%29%20of%20BES%20Sites%20whose%20%28%28External%20Site%20Flag%20of%20it%20%3D%20True%29%29%29)" https://{parameter "BFServer" of action}/api/query -o "c:\BIGSLACK\New Content.txt"

